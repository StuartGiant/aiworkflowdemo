# AI Workflow Demo — environment variables
#
# SETUP:  cp .env.example .env  then fill in every value marked <CHANGE ME>
#
# RULES:  - Never commit .env to git  (.gitignore already excludes it)
#         - Never hardcode any value in source code
#         - In production, load from GCP Secret Manager instead of this file
#
# Sections:
#   1. PostgreSQL
#   2. OpenSearch
#   3. MinIO (evidence vault)
#   4. Evidence module
#   5. Signing keys
#   6. Google Workspace connector
#   7. Content moderation
#   8. Optional overrides

# ── 1. PostgreSQL ─────────────────────────────────────────────────────────────

# Admin user created by the Postgres container on first boot.
POSTGRES_DB=aiwf
POSTGRES_ADMIN_USER=aiwf_admin
POSTGRES_ADMIN_PASSWORD=<CHANGE ME>           # min 16 chars recommended

# Application roles (least-privilege). Passwords are set by
# db/0001b_set_role_passwords.sh on first boot.
POSTGRES_WRITER_USER=evidence_writer
POSTGRES_WRITER_PASSWORD=<CHANGE ME>
POSTGRES_READER_USER=evidence_reader
POSTGRES_READER_PASSWORD=<CHANGE ME>

# Optional overrides (defaults work for local Docker stack)
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432

# ── 2. OpenSearch ─────────────────────────────────────────────────────────────

# Required by the OpenSearch container even with the security plugin disabled.
# In the demo the security plugin IS disabled; this value is not used for auth
# but the container will refuse to start without it (≥8 chars, mixed case+digit).
OPENSEARCH_ADMIN_PASSWORD=<CHANGE ME>         # e.g. Demo@12345 (demo only)

# ── 3. MinIO (evidence vault) ─────────────────────────────────────────────────

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=<CHANGE ME>               # min 8 chars

# Optional
# MINIO_REGION=us-east-1

# Bucket name — must be lowercase, no spaces
EVIDENCE_BUCKET=evidence-vault

# Service-account keys provisioned by minio-init on first boot.
# Use long random strings; treat as secrets.
EVIDENCE_WRITER_ACCESS_KEY=<CHANGE ME>        # e.g. output of: openssl rand -hex 10
EVIDENCE_WRITER_SECRET_KEY=<CHANGE ME>        # e.g. output of: openssl rand -hex 20
EVIDENCE_READER_ACCESS_KEY=<CHANGE ME>
EVIDENCE_READER_SECRET_KEY=<CHANGE ME>
EVIDENCE_ADMIN_ACCESS_KEY=<CHANGE ME>
EVIDENCE_ADMIN_SECRET_KEY=<CHANGE ME>

# Object Lock retention for the demo (short so cleanup is easy).
EVIDENCE_RETENTION_DAYS=1

# ── 4. Evidence module ────────────────────────────────────────────────────────

# Optional overrides (defaults match local Docker stack)
# S3_ENDPOINT_URL=http://127.0.0.1:9000
# S3_REGION=us-east-1
EVIDENCE_RETENTION_CLASS=demo_90d
# AUDIT_LOG_PATH=./logs/agent_audit.jsonl

# ── 5. Signing keys (Ed25519) ─────────────────────────────────────────────────
#
# Generate with:
#   openssl genpkey -algorithm ed25519 -out keys/signing_private.pem
#   openssl pkey   -in keys/signing_private.pem -pubout -out keys/signing_public.pem
#   openssl pkey   -in keys/signing_private.pem -pubout -outform DER \
#     | sha256sum | awk '{print $1}'          # <-- use as SIGNING_KEY_ID
#
# The keys/ directory is gitignored. Never commit key material.
SIGNING_PRIVATE_KEY_PATH=keys/signing_private.pem
SIGNING_PUBLIC_KEY_PATH=keys/signing_public.pem
SIGNING_KEY_ID=<CHANGE ME>                    # SHA-256 fingerprint of the public key DER

# ── 6. Google Workspace connector + bookmark_guard notifier ──────────────────
#
# Prerequisites:
#   - GCP service account with domain-wide delegation (DWD) already created
#   - The following scopes granted to the service account in Google Workspace Admin:
#       https://www.googleapis.com/auth/admin.reports.audit.readonly  (GWS ingest)
#       https://www.googleapis.com/auth/gmail.send                    (bookmark_guard: email notification)
#   - Service-account JSON key downloaded and stored outside the repo
#
# The key file path must be absolute or relative to the project root.
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/path/to/service-account-key.json
GOOGLE_WORKSPACE_ADMIN_EMAIL=admin@yourdomain.com
GOOGLE_WORKSPACE_CUSTOMER_ID=C0xxxxxxx        # format: C0xxxxxxx or primary domain

# Sender address the service account impersonates to send notification emails.
# Overrides notification.sender_email in bookmark_guard.yml when set.
# GOOGLE_NOTIFICATION_SENDER_EMAIL=stuart.chen@zeroinsiderai.com

# ── 7. Content moderation ─────────────────────────────────────────────────────
#
# Prerequisites:
#   - Anthropic API key from console.anthropic.com
#   - Additional scopes added to the service account in Google Workspace Admin:
#       https://www.googleapis.com/auth/chat.messages              (delete flagged messages)
#       https://www.googleapis.com/auth/chat.spaces.readonly       (read space metadata)
#       https://www.googleapis.com/auth/chat.memberships.readonly  (read space membership)
#       https://www.googleapis.com/auth/pubsub                     (pull Pub/Sub subscription)
#       https://www.googleapis.com/auth/cloud-vision               (image violence scoring)
#   - GCP roles on the service account:
#       roles/cloudvision.imageAnnotator   (Cloud Vision SafeSearch)
#       roles/pubsub.subscriber            (pull from Chat Events subscription)
#   - Google Chat Events API enabled in GCP Console and subscription created
#       pointing at the Pub/Sub topic for your target spaces
#   - Chat app created and published to the Workspace org (for DM notifications)

# Anthropic Claude API — LLM semantic screener (Layer 2 text moderation)
ANTHROPIC_API_KEY=<CHANGE ME>                  # sk-ant-...

# Google Cloud Pub/Sub — Chat Events subscription
PUBSUB_PROJECT_ID=<CHANGE ME>                  # GCP project ID, e.g. my-project-123
PUBSUB_SUBSCRIPTION_ID=<CHANGE ME>             # Pub/Sub subscription name, e.g. chat-events-sub
WORKSPACE_EVENTS_SUBSCRIPTION_NAME=<CHANGE ME> # Workspace Events sub name, e.g. subscriptions/chat-spaces-xxx

# Reviewer notification targets (REVIEW and BLOCK verdicts)
MODERATION_REVIEWER_EMAIL=stuart.chen@zeroinsiderai.com
MODERATION_REVIEWER_CHAT_USER_ID=<CHANGE ME>   # Chat user resource name, e.g. users/123456789

# ── 8. Optional OpenSearch overrides ─────────────────────────────────────────
# OPENSEARCH_HOST=127.0.0.1
# OPENSEARCH_PORT=9200
