{
  "manifest_version": 3,
  "name": "Bookmark Guard",
  "version": "1.0.0",
  "description": "Automatically removes bookmarks containing sensitive URLs and syncs the deletion.",

  "permissions": [
    "bookmarks",
    "storage",
    "notifications",
    "identity",
    "alarms"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
